{
  "buildCommand": "npx convex deploy --cmd \"npm run build\" --cmd-url-env-var-name VITE_CONVEX_URL",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://colorful-beagle-698.convex.site/api/:path*"
    },
    {
      "source": "/((?!llm-api\\.md$|the-library/).*)",
      "destination": "/index.html"
    }
  ]
}
