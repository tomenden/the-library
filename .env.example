# PUBLIC config only — no secrets here. This file is committed to git.
# Server-side secrets (API keys, OAuth, etc.) are stored on the Convex
# deployment via `npx convex env set` and never appear in local files.

# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=dev:your-deployment-name # team: your-team, project: the-library

VITE_CONVEX_URL=https://your-deployment-name.convex.cloud

VITE_CONVEX_SITE_URL=https://your-deployment-name.convex.site

# Uncomment to bypass auth and use mock data for UI testing
# VITE_SKIP_AUTH=true
